<%- layout("./layout/boilerplate.ejs") %>
  <div class="row">
    <div class="col-8 offset-2">
  <body>
    <h3>Create a New Listing</h3>
    
    <form method="POST" action="/listings"  novalidate class="needs-validation" 
    enctype="multipart/form-data" >
    <!-- //enctype used for uploading files in form data..eg image -->
      <div class="mb-3">
        <label for="title" class="form-label"> Enter title</label>
        <input name="listing[title]" class="form-control" 
        placeholder="title" id="title" required type="text" />
      <div class="valid-feedback">title looks good</div>
      <div class="invalid-feedback">enter a title</div>
      </div>
  
    <div class="mb-3">
      <label for="desc" class="form-label">Enter description</label>
     <textarea
        name="listing[description]"
      id="desc"
      class="form-control"
      placeholder="something better description"
      required
      ></textarea>
      <div class="valid-feedback">description looks good</div>
      <div class="invalid-feedback">enter a perfect description</div>
    </div>
  
    
      <!-- <div class="mb-3">
        <label for="image" class="form-label">enter image URL/Link</label>
          <input
        name="listing[image]"
        class="form-control"
        id="image"
        placeholder="image"
        type="text"
      
      /> <br> -->
      <div class="mb-3">
        <label for="image" class="form-label">upload image</label>
          <input
        name="listing[image]"
        class="form-control"
        id="image"
        placeholder="image"
        type="file"
        required
      
      />
      <div class="valid-feedback">image uploaded successfully</div>
      <div class="invalid-feedback">please upload an image</div>
      </div>
    
      <div class="row">
      <div class="mb-3 col-md-4">
        <label for="price" class="form-label">Enter price</label>
        <input name="listing[price]" required id="price" class="form-control" 
        placeholder="1200(*required)"  />
      <div class="valid-feedback">price looks good</div>
      <div class="invalid-feedback">enter a valid price</div>
      </div>
      
      
      <div class="mb-3 col-md-8">
        <label for="country" class="form-label">Enter country</label>
      
      <input name="listing[country]" required id=" country" class="form-control" placeholder="india" type="text" />
      
      <div class="valid-feedback">countrylooks good</div>
      <div class="invalid-feedback">enter a country name</div>
     </div> </div>
      <div class="mb-3 ">
        <label for="location" class="form-label">Location</label>
      
      <input
        name="listing[location]"
        id="location"
        class="form-control"
        type="text"
        placeholder="mumbai"
        required
      />
      <div class="valid-feedback">location looks good</div>
      <div class="invalid-feedback">enter a  perfect locatoin</div>
    </div>
      <br />
      <button class="btn btn-dark add-btn">Add</button>
    </form>
    <br>
  </body>
</div>
</div>

