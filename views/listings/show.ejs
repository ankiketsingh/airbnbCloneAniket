<%- layout("./layout/boilerplate.ejs") %>
<script>
        const coordinates= <%- JSON.stringify(listing.geometry.coordinates)%>
</script>
  
    <div class="row mt-3">  
      <div class="col-8 offset-3 ">
    
    <h3><b> <%= listing.title %></b></h3></div>
    <div class="card listingCard col-6 offset-3 show-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" 
        alt="listing iimage">
  <div class="card-body">
    <p class="card-text">
       <p>Owned by <b><i><%= listing.owner.username %></i></b></p>
       <p><%= listing.description %> </p>
       &#8377; <%= listing.price.toLocaleString("en-IN") %> <br>
       <%= listing.location %> <br>
        <%= listing.country %>
  </p>
</div>
    </div>
   <% if(currentUser && currentUser._id.equals(listing.owner._id)) { %>
    <div class="btn">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 
      offset-3 add-btn">Edit</a>
    
    <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
      <button class="btn btn-dark  offset-5">Delete </button>
    </form>
    </div>
    <% } %>

    <div class="col-8 offset-3">
      <% if(!currentUser) {  %>
        <hr>
      <div class="alert alert-info" role="alert">
        Please <a href="/users/login" class="alert-link">login</a> to leave a review.
      </div>
        <% } %>
      <% if(currentUser) {  %>
      <form action="/listings/<%= listing._id %>/reviews"
         method="POST" novalidate class="needs-validation">
      <hr>
      <h2>Leave a Review</h2>
      <!-- <div>
        <label for="rating" class="form-label">Rating</label>
        <input type="range" class="form-range" id="rating" min="1"
         max="5" name="review[rating]">
      </div> -->
      <div class="mb-3 mt-3">
      <fieldset class="starability-slot">
  <legend>First rating:</legend>
  <input 
  type="radio" 
  id="no-rate"
 class="input-no-rate" 
 name="review[rating]" 
 value="0" checked 
 aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
</div> <br>

      <div class="mb-3">
        <label for="comment" class="form-label">Comment</label>
        <textarea class="form-control" id="comment" rows="4" col="17" 
        name="review[comment]" required></textarea>
        <div class="valid-feedback">thanks</div>
      <div class="invalid-feedback">plz write a comment</div>
    </div>
  <div>
    <button class="btn btn-outline-dark">submit</button>
  </div>
  </form>
  <% } %>
  <hr>

  <% if(listing.reviews.length) { %>
  <h4>All reviews </h4>
  <div class="row">
  <% for( review of listing.reviews){ %>
    <div class="card m-3 p-3 col-5 ">
      <div class="card-body">
   
        <h5 class="card-title"><%= review.comment %></h5>
        <p class="card-text starability-result" 
         data-rating="<%= review.rating %>"></p>

        <p class="card-text"><small class="text-muted">by
           <%= review.author.username %></small></p>

        <% if(currentUser && currentUser._id.equals(review.author._id)) { %>
        <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
          <button class="btn btn-sm btn-dark">Delete</button>
        </form>
        <% } %>

      </div>
     </div>
    <br>
    <% } %>
    </div>
    <hr>
  <% } %>
  </div>
  <div class="col-8 offset-3">
    <p>where are you</p>
  <div id="map"></div>
  </div>
   </div>

   <script src="/js/map.js"></script>

