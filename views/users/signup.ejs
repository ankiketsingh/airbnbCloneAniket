<%- layout("./layout/boilerplate.ejs") %>
<div class="row">
  <div class="col-6 offset-3">
    <h3>SignUp on Wanderlust </h3>
    <form method="POST" action="/users/signup" novalidate class="needs-validation">
      <div class="mb-3">
        <label for="username" class="form-label">Enter username</label>
        <input name="username" required type="text" id="username" class="form-control" />
        <div class="valid-feedback">username looks good</div>
        <div class="invalid-feedback">enter a username</div>
      </div>
      <div class="mb-3">
        <label for="email" class="form-label">Enter email</label>
        <input name="email" required type="email" id="email" class="form-control" />
        <div class="valid-feedback">email looks good</div>
        <div class="invalid-feedback">enter a valid email</div>
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Enter password</label>
        <input name="password" required type="password" id="password" class="form-control" />
        <div class="valid-feedback">password looks good</div>
        <div class="invalid-feedback">enter a password</div>
      </div>

      <button class="btn btn-primary  ">Sign Up</button>
    </form>
    <div>
      <a class="mt-4px p-1 rounded offset-3" href="/users/login"><b>already have an account? log in</b></a>
    </div>
  </div>
</div>